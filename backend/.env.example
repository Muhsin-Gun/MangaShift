APP_NAME=MangaShift AI
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO

MODELS_DIR=./models
CACHE_DIR=./cache
LORAS_DIR=./loras
FONTS_DIR=./fonts
STYLE_PACKAGES_FILE=./style_packages.json
MODEL_MANIFEST_PATH=./models/manifest.json

MAX_CACHE_ITEMS=512
MAX_CACHE_SIZE_GB=10
REQUEST_TIMEOUT_S=120
WARMUP_TIMEOUT_S=300
OCR_MIN_CONFIDENCE=0.35

SD_INPAINT_MODEL=runwayml/stable-diffusion-inpainting
SD_IMG2IMG_MODEL=runwayml/stable-diffusion-v1-5
MARIAN_JA_EN=Helsinki-NLP/opus-mt-ja-en
MARIAN_KO_EN=Helsinki-NLP/opus-mt-ko-en
M2M100_FALLBACK=facebook/m2m100_418M

ENABLE_DIFFUSION_STYLES=true
ENABLE_DIFFUSION_INPAINT=true
ENABLE_LLM_POST_EDIT=false
ENABLE_SCENE_MEMORY=true
ENABLE_EPISODIC_MEMORY=true
ENABLE_REPAIR_PLANNER=true
ENABLE_ADAPTIVE_CONTROLLER=true
ENFORCE_IDENTITY_CONSISTENCY=true
LOCAL_MODELS_ONLY=true
STRICT_PRO_MODE=false
STRICT_REQUIRE_GPU=false
STRICT_REQUIRE_DIFFUSION=false
STRICT_REQUIRE_OCR=false
STRICT_REQUIRE_TRANSLATION_MODELS=false
QUALITY_REQUIRE_GPU=true
QUALITY_REQUIRE_FULL_PATH=true
QUALITY_CLOUD_WORKER_URL=
QUALITY_CLOUD_WORKER_TOKEN=
IDENTITY_SIMILARITY_THRESHOLD=0.78
IDENTITY_MAX_RETRIES=2
QUALITY_IDENTITY_SIMILARITY_THRESHOLD=0.78
QUALITY_STYLE_ADHERENCE_THRESHOLD=0.64
TRANSLATION_CONTEXT_WINDOW_PAGES=6
TRANSLATION_CONTEXT_WINDOW_LINES=48
QUALITY_PREVIEW_STEPS=8
QUALITY_BALANCED_STEPS=18
QUALITY_FINAL_STEPS=30
QUALITY_MASTER_STEPS=42
QUALITY_VARIANT_MIN=16
QUALITY_VARIANT_MAX=32
QUALITY_TOPK=3
CONTROLLER_TARGET_IDENTITY=0.82
CONTROLLER_TARGET_EDGE_OVERLAP=0.64
CONTROLLER_TARGET_BLUR_SCORE=0.72
EPISODIC_SIMILARITY_THRESHOLD=0.78
EPISODIC_MAX_PALETTE_COLORS=12
EPISODIC_MEMORY_PATH=./cache/episodic_memory.json
LLM_GGUF_PATH=./models/llm/translator.gguf
